# =============================================================================
# RTP Platform QA — Environment Variables Template
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================================

# --- Debtor Service Provider (primary) --------------------------------------
DEBTOR_SERVICE_PROVIDER_CLIENT_ID=
DEBTOR_SERVICE_PROVIDER_CLIENT_SECRET=
DEBTOR_SERVICE_PROVIDER_ID=

# --- Debtor Service Provider B (secondary, used in takeover tests) ----------
DEBTOR_SERVICE_PROVIDER_B_CLIENT_ID=
DEBTOR_SERVICE_PROVIDER_B_CLIENT_SECRET=
DEBTOR_SERVICE_PROVIDER_B_ID=

# --- Creditor Service Provider ----------------------------------------------
CREDITOR_SERVICE_PROVIDER_CLIENT_ID=
CREDITOR_SERVICE_PROVIDER_CLIENT_SECRET=
CREDITOR_SERVICE_PROVIDER_ID=

# --- RTP Consumer / Sender (used in BDD send tests via GPD endpoint) --------
RTP_CONSUMER_CLIENT_ID=
RTP_CONSUMER_CLIENT_SECRET=

# --- RTP Reader -------------------------------------------------------------
RTP_READER_CLIENT_ID=
RTP_READER_CLIENT_SECRET=

# --- Read RTP Activations ---------------------------------------------------
READ_RTP_ACTIVATIONS_CLIENT_ID=
READ_RTP_ACTIVATIONS_CLIENT_SECRET=

# --- PagoPA Integration — Payee Registry ------------------------------------
PAGOPA_INTEGRATION_PAYEE_REGISTRY_CLIENT_ID=
PAGOPA_INTEGRATION_PAYEE_REGISTRY_CLIENT_SECRET=
PAGOPA_INTEGRATION_PAYEE_REGISTRY_CONSENT_CLIENT_ID=
PAGOPA_INTEGRATION_PAYEE_REGISTRY_CONSENT_CLIENT_SECRET=
PAGOPA_INTEGRATION_SERVICE_REGISTRY_CLIENT_ID=
PAGOPA_INTEGRATION_SERVICE_REGISTRY_CLIENT_SECRET=

# --- CBI --------------------------------------------------------------------
CBI_CLIENT_ID=
CBI_CLIENT_SECRET=
CBI_CLIENT_PFX_BASE64=          # Base64-encoded PFX certificate
CBI_CLIENT_PFX_PASSWORD_BASE64= # Base64-encoded PFX password
CBI_ACTIVATED_FISCAL_CODE=      # Fiscal code pre-activated for CBI tests
CBI_PAYEE_ID=
CREDITOR_AGENT_ID=

# --- Poste Italiane ---------------------------------------------------------
POSTE_CLIENT_ID=
POSTE_CLIENT_SECRET=
POSTE_ACTIVATED_FISCAL_CODE=    # Fiscal code pre-activated for Poste tests

# --- ICCREA -----------------------------------------------------------------
ICCREA_ACTIVATED_FISCAL_CODE=   # Fiscal code pre-activated for ICCREA tests

# --- Mock Service Provider --------------------------------------------------
DEBTOR_SERVICE_PROVIDER_MOCK_PFX_BASE64=          # Base64-encoded mock PFX
DEBTOR_SERVICE_PROVIDER_MOCK_PFX_PASSWORD_BASE64= # Base64-encoded mock PFX password
MOCK_ACTC_FISCAL_CODE=          # Triggers synchronous ACTC response (DS-05)
MOCK_RJCT_FISCAL_CODE=          # Triggers synchronous RJCT response (DS-08P N)
MOCK_NO_LINKS_FISCAL_CODE=      # Triggers ACTC without _links field
MOCK_EXTRA_FIELD_FISCAL_CODE=   # Triggers non-compliant ACTC with extra field
MOCK_RJCT_EXTRA_FIELD_FISCAL_CODE= # Triggers non-compliant RJCT with extra field
MOCK_RJCT_NO_LINKS_FISCAL_CODE=    # Triggers RJCT without _links field
MOCK_SERVER_ERROR_FISCAL_CODE=     # Triggers 502 server error response from mock

# --- GPD (Debt Positions) — UAT ---------------------------------------------
DEBT_POSITIONS_SUBSCRIPTION_KEY=
DEBT_POSITIONS_ORGANIZATION_ID=
EC_TAX_CODE=                    # EC fiscal code for GPD payloads

# --- GPD (Debt Positions) — DEV ---------------------------------------------
DEBT_POSITIONS_DEV_SUBSCRIPTION_KEY=
DEBT_POSITIONS_DEV_ORGANIZATION_ID=

# --- Web Application (UX tests) ---------------------------------------------
WEBPAGE_USERNAME=
WEBPAGE_PASSWORD=
WEBPAGE_CLIENT_ID=
WEBPAGE_PAYER_FISCAL_CODE=         # Fiscal code of the pre-activated payer used in UX tests
